{
  "name": "opencode-wechat-channel",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenCode WeChat Channel Plugin - Bridge WeChat messages into OpenCode sessions",
  "bin": {
    "opencode-wechat-channel": "bin/cli.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsdown src/index.ts",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.17.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opencode-ai/sdk": "^1.3.5",
    "qrcode-terminal": "^0.12.0",
    "weixin-bot-plugin": "^2.0.1",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsdown": "^0.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "opencode",
    "wechat",
    "mcp",
    "channel",
    "plugin"
  ],
  "license": "MIT"
}
